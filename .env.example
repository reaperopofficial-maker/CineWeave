# CineWeave Environment Variables

# Claude AI (Required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# GeminiGen.ai (Required)
GEMINIGEN_API_KEY=your_key_here
GEMINIGEN_IMAGE_MODEL=imagen-4-ultra
GEMINIGEN_IMAGE_MODEL_FAST=nano-banana
GEMINIGEN_VIDEO_MODEL=veo-3.1
GEMINIGEN_VIDEO_MODEL_FAST=veo-3-fast

# App Config
SECRET_KEY=your-random-secret-key
DATABASE_URL=sqlite+aiosqlite:///./cineweave.db
DEV_MODE=true
VITE_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
MAX_CONCURRENT_IMAGES=3
MAX_CONCURRENT_VIDEOS=1
PROJECTS_DIR=./projects
